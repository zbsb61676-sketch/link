// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("RENTER") // RENTER, OWNER, ADMIN
  paypalEmail   String?
  bankDetails   String?
  upiId         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resetToken    String?   @unique
  resetTokenExpiry DateTime?
  hasReceivedDripEmail Boolean @default(false)

  listings      AccountListing[]
  rentals       Rental[]
  payments      PaymentRecord[]
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  reportedDisputes  Dispute[]
}

model AccountListing {
  id            String    @id @default(cuid())
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  connections   Int
  accountAge    String
  location      String
  price         Float
  rating        Float     @default(0.0)
  isVerified    Boolean   @default(false)
  status        String    @default("AVAILABLE") // AVAILABLE, RENTED, PAUSED
  
  linkedinUrl    String?
  whatsappNumber String?
  verificationCode String?
  screenshotBase64 String?  @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rentals       Rental[]

  @@index([ownerId])
  @@index([status])
}

model Rental {
  id            String    @id @default(cuid())
  listingId     String
  listing       AccountListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  renterId      String
  renter        User      @relation(fields: [renterId], references: [id], onDelete: Cascade)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  status        String    @default("ACTIVE") // ACTIVE, CANCELLED, COMPLETED
  
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  lastHealthStatus String   @default("HEALTHY") // HEALTHY, NEEDS_REVIEW
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  disputes      Dispute[]
  payments      PaymentRecord[]

  @@index([status])
  @@index([listingId])
  @@index([renterId])
}

model PaymentRecord {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rentalId      String?
  rental        Rental?   @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  
  amount        Float
  paymentDate   DateTime  @default(now())
  reference     String?
  
  status        String    @default("PENDING") // PENDING, REQUESTED, VERIFIED, COMPLETED, CANCELLED
  releaseDate   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([rentalId])
}

model Dispute {
  id          String   @id @default(cuid())
  rentalId    String
  rental      Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason      String
  status      String   @default("OPEN") // OPEN, RESOLVED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rentalId])
  @@index([reporterId])
}

model Message {
  id          String   @id @default(cuid())
  content     String
  imageUrl    String?  // Base64 encoded image or URL
  read        Boolean  @default(false)
  
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([read])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
